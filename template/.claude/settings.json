{
  "permissions": {
    "allow": [
      "mcp__agent-collab__*",
      "Read(*)",
      "Grep(*)",
      "Write(*)",
      "Edit(*)"
    ]
  },
  "mcpServers": {
    "agent-collab": {
      "command": "node",
      "args": ["./agent-collab-mcp/build/index.js"],
      "env": {
        "AGENT_ROLE": "claude-code"
      }
    }
  }
}
